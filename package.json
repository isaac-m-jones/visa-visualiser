{
  "name": "visa-visualiser",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "db:build:starter": "node server/scripts/buildStarterDataset.js",
    "db:import": "node server/scripts/importDataset.js",
    "db:provision:starter": "npm run db:build:starter && npm run db:import -- --file server/data/snapshots/starter-dataset.generated.json",
    "db:status": "node server/scripts/dbStatus.js",
    "db:fetch:passport-index": "node server/scripts/fetchPassportIndex.js",
    "db:sync:passport-index": "node server/scripts/syncPassportIndex.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "maplibre-gl": "^5.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-maps": "^3.0.0",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "vite": "^5.4.14"
  }
}
